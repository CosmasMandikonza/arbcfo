# ArbCFO AI Agent Configuration
# Copy to .env and fill in your values

# Required for AI-powered invoice parsing
OPENAI_API_KEY=sk-your-openai-api-key

# Required for on-chain submission (optional for parse-only mode)
PRIVATE_KEY=0xYOUR_OPERATOR_PRIVATE_KEY
VAULT_ADDRESS=0xYOUR_DEPLOYED_VAULT_ADDRESS
USDC_ADDRESS=0xYOUR_DEPLOYED_MOCK_USDC_ADDRESS

# Optional
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBCFO_API_URL=http://localhost:3000
